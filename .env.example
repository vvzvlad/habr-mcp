# Habr MCP server configuration.
# Read tools (search/list/get article/comments) work WITHOUT any credentials.
# Only write tools (post comment, vote, bookmark) need HABR_CONNECT_SID + HABR_CSRF_TOKEN.

# Content/flow language (fl) and interface language (hl). Default: ru.
HABR_LANG=ru

# --- Write auth (optional; leave empty for read-only) ---
# How to obtain, while logged in to habr.com in your browser:
#   HABR_CONNECT_SID: DevTools -> Application -> Cookies -> habr.com ->
#                     copy the value of the `connect.sid` cookie.
#   HABR_CSRF_TOKEN:  DevTools -> Network -> trigger any write request (e.g. vote)
#                     -> open it -> Request Headers -> copy the `csrf-token` value
#                     (it equals the `csrf_token` cookie value).
HABR_CONNECT_SID=
HABR_CSRF_TOKEN=
# Name of the CSRF cookie that must echo the token (double-submit cookie).
HABR_CSRF_COOKIE_NAME=csrf_token

# Optional HTTP or SOCKS proxy URL, e.g. socks5://127.0.0.1:1080
PROXY=

# httpx request timeout in seconds.
REQUEST_TIMEOUT=20

# Browser-like User-Agent (override only if needed).
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# Page size for feeds / search.
PER_PAGE=20
