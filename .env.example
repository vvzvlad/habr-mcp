# Habr MCP server configuration (HTTP-only, multi-tenant).
#
# This server is HTTP-only and multi-tenant: there are NO per-user credentials
# in this file. Each user authenticates with their own opaque bearer token in
# their MCP client config (Authorization: Bearer <token>) and saves their Habr
# session once via the habr_login tool. Per-token credentials are stored,
# encrypted at rest, under HABR_MCP_STATE_DIR.
#
# This file only configures SHARED, non-secret server options.

# --- HTTP transport ---
# Bind address and port for the streamable-http server.
# In Docker this MUST be 0.0.0.0 so the container binds all interfaces
# (the docker-compose.yml sets it); 127.0.0.1 is local-only.
HABR_MCP_HOST=127.0.0.1
HABR_MCP_PORT=8765
# Directory for the per-token credential store (creds.json, mode 0600).
# All mutable state lives under data/ (the docker volume mount point).
HABR_MCP_STATE_DIR=data

# Content/flow language (fl) and interface language (hl). Default: ru.
HABR_LANG=ru

# Value for the `x-app-version` request header (Habr frontend version).
HABR_X_APP_VERSION=2.329.0

# --- Docmost image reupload (optional) ---
# Base URL to download Docmost image attachments for reupload, e.g. https://docs.example.com
DOCMOST_BASE_URL=
# Bearer token to download Docmost attachments.
DOCMOST_API_TOKEN=

# Optional HTTP or SOCKS proxy URL, e.g. socks5://127.0.0.1:1080
PROXY=

# httpx request timeout in seconds.
REQUEST_TIMEOUT=20

# Browser-like User-Agent (override only if needed).
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# Page size for feeds / search.
PER_PAGE=20
